generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organizations & Users ───────────────────────────────────────────────

enum UserRole {
  PATIENT
  CLINICIAN
  CLINIC_ADMIN
  PAYER
}

enum RecoveryPhase {
  IN_CLINIC_PT
  POST_DISCHARGE
  RETURN_TO_SPORT
  MAINTENANCE
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Clinic {
  id        String   @id @default(cuid())
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  patients       PatientProfile[]
  exercises      Exercise[]
  subscription   ClinicSubscription?
  ehrConnections EhrConnection[]
  devices        Device[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole
  clinicId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic           Clinic?           @relation(fields: [clinicId], references: [id])
  patientProfile   PatientProfile?
  clinicianProfile ClinicianProfile?
  payerProfile     PayerProfile?
  xpEvents         XpEvent[]
  achievements     Achievement[]
  chatMessages     ChatMessage[]
}

model ClinicianProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  licenseNumber   String?
  specialty       String?
  onboardingCode  String  @unique @default(cuid())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  patients PatientProfile[]  @relation("AssignedClinician")
}

// ─── Patient Recovery Journey ────────────────────────────────────────────

model PatientProfile {
  id                String        @id @default(cuid())
  userId            String        @unique
  clinicId          String?
  clinicianId       String?
  injuryType        String
  injuryDate        DateTime?
  sport             String?
  sportGoal         String?
  comorbidities     String[]
  recoveryPhase     RecoveryPhase @default(POST_DISCHARGE)
  clinicianCodeUsed String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic     Clinic?           @relation(fields: [clinicId], references: [id])
  clinician  ClinicianProfile? @relation("AssignedClinician", fields: [clinicianId], references: [id])

  checkIns          DailyCheckIn[]
  programs          AssignedProgram[]
  outcomeSurveys    OutcomeSurvey[]
  readinessScores   ReadinessScore[]
  sessionLogs       ExerciseSession[]
  alerts            Alert[]
  workoutFeedback   WorkoutFeedback[]
  clinicianNotes    ClinicianNote[]
  rtmEnrollment     RtmEnrollment?
  devices           Device[]
  sensorSessions    SensorSession[]
  xpTotal           Int              @default(0)
  level             Int              @default(1)
}

// ─── Daily Accountability ──────────────────────────────────────────────────

model DailyCheckIn {
  id              String   @id @default(cuid())
  patientId       String
  date            DateTime @db.Date
  painScore       Int      // 0-10 validated scale
  confidenceScore Int      // 0-10 psychological readiness
  moodNote        String?
  symptoms        String[]
  voiceNoteUrl    String?
  createdAt       DateTime @default(now())

  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, date])
}

// ─── Home Exercise Programs ────────────────────────────────────────────────

model Exercise {
  id           String   @id @default(cuid())
  clinicId     String?
  name         String
  description  String
  instructions String
  videoUrl     String?
  muxAssetId   String?
  bodyRegion   String
  difficulty   Int      @default(1) // 1-5
  isGlobal     Boolean  @default(false)
  createdAt    DateTime @default(now())

  clinic       Clinic?              @relation(fields: [clinicId], references: [id])
  programItems ProgramExercise[]
}

model AssignedProgram {
  id          String    @id @default(cuid())
  patientId   String
  name        String
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  frequency   String    @default("daily") // daily, 3x/week, etc.
  createdAt   DateTime  @default(now())

  patient  PatientProfile    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  exercises ProgramExercise[]
}

model ProgramExercise {
  id          String @id @default(cuid())
  programId   String
  exerciseId  String
  sets        Int    @default(3)
  reps        Int    @default(10)
  holdSeconds Int?
  orderIndex  Int    @default(0)
  notes       String?

  program  AssignedProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercise Exercise        @relation(fields: [exerciseId], references: [id])
  sessions ExerciseSession[]
}

model ExerciseSession {
  id                String    @id @default(cuid())
  patientId         String
  programExerciseId String
  completedAt       DateTime  @default(now())
  setsCompleted     Int
  repsCompleted     Int
  durationSeconds   Int?      // wall-clock time spent on this exercise
  painDuring        Int?      // 0-10 during exercise
  formScore         Float?    // 0-100 from CV/sensor
  sensorDataUrl     String?
  videoRecordingUrl String?
  notes             String?

  patient         PatientProfile  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  programExercise ProgramExercise @relation(fields: [programExerciseId], references: [id])
  workoutFeedback WorkoutFeedback[]
}

// ─── Return-to-Play Readiness ─────────────────────────────────────────────

enum SurveyType {
  KOOS
  IKDC
  CUSTOM
}

model OutcomeSurvey {
  id         String     @id @default(cuid())
  patientId  String
  surveyType SurveyType
  scores     Json       // domain scores as structured JSON
  totalScore Float
  completedAt DateTime  @default(now())

  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model ReadinessScore {
  id              String   @id @default(cuid())
  patientId       String
  overallScore    Float    // 0-100 composite
  physicalScore   Float
  psychologicalScore Float
  adherenceScore  Float
  functionalScore Float
  recommendation  String   // e.g. "Not ready", "Progressing", "Clear for light activity"
  calculatedAt    DateTime @default(now())

  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// ─── Post-Workout Feedback ───────────────────────────────────────────────

model WorkoutFeedback {
  id                String   @id @default(cuid())
  patientId         String
  exerciseSessionId String?  // links feedback to the exercise it followed, when known
  painScore         Int      // 0-10, pain during/after the workout
  difficulty        Int      // 0-10, perceived difficulty
  comments          String?
  submittedAt       DateTime @default(now())

  patient         PatientProfile   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  exerciseSession ExerciseSession? @relation(fields: [exerciseSessionId], references: [id])
}

// ─── Clinician Alerts (low-burden visibility) ───────────────────────────

enum AlertType {
  MISSED_SESSIONS
  HIGH_PAIN
  LOW_ADHERENCE
  FORM_DEGRADATION
  READINESS_MILESTONE
  SURVEY_DUE
}

model Alert {
  id        String        @id @default(cuid())
  patientId String
  type      AlertType
  severity  AlertSeverity
  message   String
  isRead    Boolean       @default(false)
  createdAt DateTime      @default(now())

  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// ─── Gamified Recovery ───────────────────────────────────────────────────

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  code        String
  title       String
  description String
  earnedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
}

// ─── AI Support Chat History ─────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" | "ai"
  text      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Clinician Notes & Clinical Workflow ─────────────────────────────────

model ClinicianNote {
  id        String   @id @default(cuid())
  patientId String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// ─── RTM Billing Engine (CPT 98975–98981) ────────────────────────────────

enum RtmStatus {
  ACTIVE
  PAUSED
  ENDED
}

model RtmEnrollment {
  id              String    @id @default(cuid())
  patientId       String    @unique
  enrolledAt      DateTime  @default(now())
  status          RtmStatus @default(ACTIVE)
  billingCodeBase String    @default("98975") // setup / education
  targetMinutes   Int       @default(20)      // monthly interactive minutes

  patient        PatientProfile    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  dayLogs        RtmDayLog[]
  communications RtmCommunication[]
  claimExports   RtmClaimExport[]
}

model RtmDayLog {
  id           String   @id @default(cuid())
  enrollmentId String
  date         DateTime @db.Date
  hasData      Boolean  @default(true) // transmission / recorded data day
  minutes      Int      @default(0)
  source       String   @default("session") // session | check_in | sensor | clinician

  enrollment RtmEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, date])
}

model RtmCommunication {
  id           String   @id @default(cuid())
  enrollmentId String
  minutes      Int
  note         String?
  occurredAt   DateTime @default(now())

  enrollment RtmEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model RtmClaimExport {
  id           String   @id @default(cuid())
  enrollmentId String
  periodStart  DateTime @db.Date
  periodEnd    DateTime @db.Date
  cptCodes     String[] // e.g. ["98975","98977","98980"]
  dataDays     Int
  totalMinutes Int
  payload      Json
  createdAt    DateTime @default(now())

  enrollment RtmEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

// ─── EHR / PMS Integrations ──────────────────────────────────────────────

enum EhrVendor {
  EPIC
  ATHENA
  PRACTICE_FUSION
  WEBPT
  OTHER
}

enum EhrConnectionStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
}

model EhrConnection {
  id           String              @id @default(cuid())
  clinicId     String
  vendor       EhrVendor
  status       EhrConnectionStatus @default(PENDING)
  externalOrgId String?
  connectedAt  DateTime?
  lastSyncAt   DateTime?
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, vendor])
}

// ─── Clinic SaaS Subscription ($80/patient/month) ────────────────────────

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

model ClinicSubscription {
  id               String             @id @default(cuid())
  clinicId         String             @unique
  status           SubscriptionStatus @default(TRIAL)
  pricePerPatient  Int                @default(80) // USD
  activeSeats      Int                @default(0)
  billingEmail     String?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

// ─── Payer Stakeholder ───────────────────────────────────────────────────

model PayerOrganization {
  id        String   @id @default(cuid())
  name      String
  region    String?  // e.g. "California"
  createdAt DateTime @default(now())

  profiles PayerProfile[]
}

model PayerProfile {
  id         String @id @default(cuid())
  userId     String @unique
  payerOrgId String
  title      String?

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  payerOrg PayerOrganization @relation(fields: [payerOrgId], references: [id], onDelete: Cascade)
}

// ─── EMG + IMU Device / Sensor Data Plane ────────────────────────────────

enum DeviceType {
  EMG_BAND
  IMU
  COMBINED
  CAMERA_ONLY
}

enum DeviceStatus {
  PAIRED
  ACTIVE
  INACTIVE
  RETIRED
}

model Device {
  id           String       @id @default(cuid())
  clinicId     String?
  patientId    String?
  type         DeviceType
  status       DeviceStatus @default(PAIRED)
  serialNumber String       @unique
  label        String?
  pairedAt     DateTime     @default(now())
  lastSeenAt   DateTime?

  clinic   Clinic?         @relation(fields: [clinicId], references: [id])
  patient  PatientProfile? @relation(fields: [patientId], references: [id])
  sessions SensorSession[]
}

model SensorSession {
  id          String   @id @default(cuid())
  deviceId    String
  patientId   String
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  exerciseName String?
  summary     Json?    // aggregated EMG RMS, IMU ROM, etc.

  device  Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  samples SensorSample[]
}

model SensorSample {
  id        String   @id @default(cuid())
  sessionId String
  recordedAt DateTime @default(now())
  channel   String   // e.g. "emg_ch1", "imu_accel", "imu_gyro"
  value     Float
  unit      String   // "mV", "g", "deg/s"

  session SensorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
